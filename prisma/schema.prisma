generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String     @id @default(cuid())
  name             String
  email            String     @unique
  password         String
  role             Role       @default(FACULTY)
  status           UserStatus @default(ACTIVE)
  
  // Password reset tokens
  resetToken       String?    @unique
  resetTokenExpiry DateTime?

  // Academic placement
  department       String?
  college          String?

  // User relations
  papers                Paper[]
  passwordResetRequests PasswordResetRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum UserStatus {
  PENDING
  ACTIVE
  INACTIVE
  REJECTED
}

enum Role {
  FACULTY
  HOD
  DEAN
  VC
  ADMIN
}

model Paper {
  id       String  @id @default(cuid())
  title    String
  authors  String?
  abstract String? @db.Text
  keywords String?
  pdfUrl   String

  // Paper activity
  downloads     Int      @default(0)
  submittedDate DateTime @default(now())

  // Owner
  uploadedBy   User   @relation(fields: [uploadedById], references: [id])
  uploadedById String

  // Academic placement
  department String?
  college    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Department {
  id        String   @id @default(cuid())
  name      String   @unique
  collegeId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model College {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AccessRequest {
  id         String        @id @default(cuid())
  name       String
  email      String
  role       Role
  department String?
  college    String?
  reason     String?       @db.Text
  status     RequestStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Admin-reviewed password reset requests
model PasswordResetRequest {
  id        String        @id @default(cuid())
  email     String
  status    RequestStatus @default(PENDING)
  
  // User that requested the reset
  userId    String?
  user      User?         @relation(fields: [userId], references: [id])
  
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}
